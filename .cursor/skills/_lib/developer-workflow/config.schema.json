{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Developer workflow local config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "github": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "defaultRemote": { "type": "string" },
        "staleDays": { "type": "number", "minimum": 1 },
        "requiredLabels": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ticket": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prefix": { "type": "string" },
        "pattern": { "type": "string" },
        "customFieldName": { "type": "string" }
      }
    },
    "asana": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tokenEnv": { "type": "string" },
        "tokenShellFallback": { "type": "boolean" },
        "workspace": { "$ref": "#/$defs/namedGid" },
        "user": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "gid": { "type": "string" },
            "name": { "type": "string" },
            "email": { "type": "string" }
          }
        },
        "project": { "$ref": "#/$defs/namedGid" },
        "customFields": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "gid": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string" }
            },
            "required": ["gid"]
          }
        },
        "statusOptions": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "sections": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/namedGid" }
        }
      }
    },
    "slack": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "statusChannel": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        }
      }
    },
    "diary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dir": { "type": "string" },
        "enabled": { "type": "boolean" }
      }
    },
    "watchedDependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "ticket": { "type": "string" },
          "asanaTaskGid": { "type": "string" },
          "name": { "type": "string" },
          "unblocks": { "type": "string" }
        },
        "required": ["asanaTaskGid", "name"]
      }
    }
  },
  "$defs": {
    "namedGid": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gid": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["gid"]
    }
  }
}
