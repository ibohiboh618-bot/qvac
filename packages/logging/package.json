{
  "name": "@qvac/logging",
  "version": "0.1.1",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "lint": "lunte",
    "lint:fix": "lunte --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "npm run lint && npm run format && npm run test:unit",
    "test:unit": "npm run test:unit:generate && bare test/unit/all.js",
    "test:unit:generate": "brittle -r test/unit/all.js test/unit/*.test.js"
  },
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/qvac.git",
    "directory": "packages/logging"
  },
  "bugs": "https://github.com/tetherto/qvac/issues",
  "homepage": "https://qvac.tether.io",
  "devDependencies": {
    "brittle": "^3.15.0",
    "lunte": "^1.8.1",
    "prettier": "^3.8.4",
    "prettier-config-holepunch": "^2.0.0"
  },
  "imports": {
    "./env": {
      "bare": "bare-env",
      "default": "./env.js"
    }
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./constants": {
      "types": "./constants.d.ts",
      "default": "./constants.js"
    },
    "./constants.js": {
      "types": "./constants.d.ts",
      "default": "./constants.js"
    }
  },
  "dependencies": {
    "bare-env": "^3.0.0"
  }
}
