{
  "name": "@qvac/logging",
  "version": "0.1.1",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run test:unit",
    "test:unit": "npm run test:unit:generate && bare test/unit/all.js",
    "test:unit:generate": "brittle -r test/unit/all.js test/unit/*.test.js"
  },
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/qvac.git",
    "directory": "packages/logging"
  },
  "bugs": "https://github.com/tetherto/qvac/issues",
  "homepage": "https://github.com/tetherto/qvac/tree/main/packages/logging#readme",
  "devDependencies": {
    "brittle": "^3.15.0",
    "standard": "^17.1.2"
  },
  "imports": {
    "./env": {
      "bare": "bare-env",
      "default": "./env.js"
    }
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./constants": {
      "types": "./constants.d.ts",
      "default": "./constants.js"
    },
    "./constants.js": {
      "types": "./constants.d.ts",
      "default": "./constants.js"
    }
  },
  "dependencies": {
    "bare-env": "^3.0.0"
  }
}
