# Ignore model and image files placed here by scripts/copy-mobile-test-assets.js.
# The script copies GGUF models (renamed to *.gguf.bin so metro treats them as
# binary assets) and the sample image from samples/english.png.
# All files here are derived artifacts and must not be committed.
*.gguf
*.bin
*.png

# Keep this directory tracked.
!.gitignore
