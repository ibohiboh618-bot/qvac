{
  "dependencies": [
    {
      "name": "opencl",
      "platform": "android"
    },
    "picojson",
    "nlohmann-json",
    {
      "name": "qvac-fabric",
      "version>=": "8828.0.2#1"
    },
    {
      "name": "qvac-lib-inference-addon-cpp",
      "version>=": "1.2.1"
    },
    {
      "name": "qvac-lint-cpp",
      "version>=": "1.4.4#3"
    }
  ],
  "default-features": [
    "openmp"
  ],
  "features": {
    "tests": {
      "description": "Build tests",
      "dependencies": [
        "gtest"
      ]
    },
    "vk-profiling": {
      "description": "Force vk performance logging in qvac-fabric",
      "dependencies": [
        {
          "name": "qvac-fabric",
          "version>=": "8828.0.2#1",
          "features": [
            "force-profiler"
          ]
        }
      ]
    },
    "openmp": {
      "description": "Enable openmp on Android.",
      "dependencies": [
        {
          "name": "qvac-fabric",
          "version>=": "8828.0.2#1",
          "features": [
            "openmp"
          ],
          "platform": "android & arm64"
        }
      ]
    }
  }
}
