@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/qvac-fabricTargets.cmake")

# Mobile builds ship the static llama/ggml libraries plus their upstream cmake
# configs — provide qvac-fabric::qvac-fabric-static for static linking.
if(EXISTS "${PACKAGE_PREFIX_DIR}/share/llama")
  list(PREPEND CMAKE_PREFIX_PATH "${PACKAGE_PREFIX_DIR}")

  include(CMakeFindDependencyMacro)
  find_dependency(ggml CONFIG)
  find_dependency(llama CONFIG)

  if(NOT TARGET qvac-fabric::qvac-fabric-static)
    add_library(qvac-fabric::qvac-fabric-static INTERFACE IMPORTED)
    set_target_properties(qvac-fabric::qvac-fabric-static PROPERTIES
      INTERFACE_LINK_LIBRARIES
        "qvac-fabric::headers;llama::llama;llama::common;llama::mtmd")
  endif()
endif()

check_required_components(qvac-fabric)
