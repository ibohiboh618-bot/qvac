+// QVAC: mark the build-info globals for export when building the shared
+// qvac-fabric runtime so consumer addons can import them across the DLL
+// boundary on Windows (see common.h). This translation unit does not include
+// common.h, so it carries its own marker. No-op on ELF/Mach-O.
+#if defined(_WIN32) && defined(QVAC_FABRIC_BUILD)
+#  define QVAC_COMMON_API __declspec(dllexport)
+#else
+#  define QVAC_COMMON_API
+#endif
+
+QVAC_COMMON_API int LLAMA_BUILD_NUMBER = @LLAMA_BUILD_NUMBER@;
+QVAC_COMMON_API char const *LLAMA_COMMIT = "@LLAMA_BUILD_COMMIT@";
+QVAC_COMMON_API char const *LLAMA_COMPILER = "@BUILD_COMPILER@";
+QVAC_COMMON_API char const *LLAMA_BUILD_TARGET = "@BUILD_TARGET@";
