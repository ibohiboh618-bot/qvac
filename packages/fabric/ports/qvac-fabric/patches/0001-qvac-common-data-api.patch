--- a/common/common.h	2026-06-02 16:16:41.907051845 +0200
+++ b/common/common.h	2026-06-02 16:16:51.662050259 +0200
@@ -53,11 +53,31 @@
 
 using llama_tokens = std::vector<llama_token>;
 
+// QVAC: the qvac-fabric runtime is shipped as a single shared library and the
+// inference addons link against it dynamically. MSVC cannot resolve cross-DLL
+// data references without an explicit import attribute, so the `common` data
+// globals below carry a dllexport/dllimport marker on Windows. QVAC_FABRIC_BUILD
+// is defined only while building the fabric runtime itself (the vcpkg port and
+// the bare addon that hosts it); consumers leave it undefined and pick up the
+// dllimport declaration. It is a no-op on ELF/Mach-O, which import data
+// transparently.
+#ifndef QVAC_COMMON_API
+#  if defined(_WIN32)
+#    if defined(QVAC_FABRIC_BUILD)
+#      define QVAC_COMMON_API __declspec(dllexport)
+#    else
+#      define QVAC_COMMON_API __declspec(dllimport)
+#    endif
+#  else
+#    define QVAC_COMMON_API
+#  endif
+#endif
+
 // build info
-extern int LLAMA_BUILD_NUMBER;
-extern const char * LLAMA_COMMIT;
-extern const char * LLAMA_COMPILER;
-extern const char * LLAMA_BUILD_TARGET;
+extern QVAC_COMMON_API int LLAMA_BUILD_NUMBER;
+extern QVAC_COMMON_API const char * LLAMA_COMMIT;
+extern QVAC_COMMON_API const char * LLAMA_COMPILER;
+extern QVAC_COMMON_API const char * LLAMA_BUILD_TARGET;
 
 const static std::string build_info("b" + std::to_string(LLAMA_BUILD_NUMBER) + "-" + LLAMA_COMMIT);
 
