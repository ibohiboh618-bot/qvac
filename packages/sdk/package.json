  "homepage": "https://qvac.tether.io",
  "keywords": [
    "ai",
    "bare",
    "cross-platform",
    "deep-learning",
    "diffusion",
    "edge-ai",
    "embeddings",
    "expo",
    "gguf",
    "gpu",
    "holepunch",
    "hyperswarm",
    "image-generation",
    "inference",
