{
  "name": "@qvac/bare-sdk",
  "version": "0.13.0",
  "license": "Apache-2.0",
  "description": "Bare-targeted slim assembly of the QVAC SDK. Consumers install only the addon packages they need and register plugins explicitly. No addon dependencies pulled in by default.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/qvac.git",
    "directory": "packages/bare-sdk"
  },
  "bugs": "https://github.com/tetherto/qvac/issues",
  "homepage": "https://github.com/tetherto/qvac/tree/main/packages/bare-sdk#readme",
  "keywords": [
    "ai",
    "bare",
    "deep-learning",
    "diffusion",
    "edge-ai",
    "embeddings",
    "gguf",
    "holepunch",
    "hyperswarm",
    "image-generation",
    "inference",
    "large-language-model",
    "llama-cpp",
    "llm",
    "local",
    "local-ai",
    "machine-learning",
    "ml",
    "model-registry",
    "ocr",
    "offline",
    "on-device",
    "p2p",
    "pear",
    "peer-to-peer",
    "private-ai",
    "qvac",
    "rag",
    "sdk",
    "self-hosted",
    "slim",
    "speech-to-text",
    "stt",
    "tether",
    "text-to-speech",
    "transcription",
    "translation",
    "tts",
    "typescript",
    "whisper"
  ],
  "type": "module",
  "main": "./dist/_sdk/index.js",
  "types": "./dist/_sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/_sdk/index.d.ts",
      "import": "./dist/_sdk/index.js",
      "require": "./dist/_sdk/index.js"
    },
    "./package": "./package.json",
    "./llamacpp-completion/plugin": {
      "types": "./dist/_sdk/server/bare/plugins/llamacpp-completion/plugin.d.ts",
      "import": "./dist/_sdk/server/bare/plugins/llamacpp-completion/plugin.js"
    },
    "./llamacpp-embedding/plugin": {
      "types": "./dist/_sdk/server/bare/plugins/llamacpp-embedding/plugin.d.ts",
      "import": "./dist/_sdk/server/bare/plugins/llamacpp-embedding/plugin.js"
    },
    "./whispercpp-transcription/plugin": {
      "types": "./dist/_sdk/server/bare/plugins/whispercpp-transcription/plugin.d.ts",
      "import": "./dist/_sdk/server/bare/plugins/whispercpp-transcription/plugin.js"
    },
    "./parakeet-transcription/plugin": {
      "types": "./dist/_sdk/server/bare/plugins/parakeet-transcription/plugin.d.ts",
      "import": "./dist/_sdk/server/bare/plugins/parakeet-transcription/plugin.js"
    },
    "./nmtcpp-translation/plugin": {
      "types": "./dist/_sdk/server/bare/plugins/nmtcpp-translation/plugin.d.ts",
      "import": "./dist/_sdk/server/bare/plugins/nmtcpp-translation/plugin.js"
    },
    "./tts-ggml/plugin": {
      "types": "./dist/_sdk/server/bare/plugins/tts-ggml/plugin.d.ts",
      "import": "./dist/_sdk/server/bare/plugins/tts-ggml/plugin.js"
    },
    "./onnx-tts/plugin": {
      "types": "./dist/_sdk/server/bare/plugins/tts-ggml/plugin.d.ts",
      "import": "./dist/_sdk/server/bare/plugins/tts-ggml/plugin.js"
    },
    "./onnx-ocr/plugin": {
      "types": "./dist/_sdk/server/bare/plugins/onnx-ocr/plugin.d.ts",
      "import": "./dist/_sdk/server/bare/plugins/onnx-ocr/plugin.js"
    },
    "./sdcpp-generation/plugin": {
      "types": "./dist/_sdk/server/bare/plugins/sdcpp-generation/plugin.d.ts",
      "import": "./dist/_sdk/server/bare/plugins/sdcpp-generation/plugin.js"
    },
    "./ggml-vla/plugin": {
      "types": "./dist/_sdk/server/bare/plugins/ggml-vla/plugin.d.ts",
      "import": "./dist/_sdk/server/bare/plugins/ggml-vla/plugin.js"
    },
    "./ggml-classification/plugin": {
      "types": "./dist/_sdk/server/bare/plugins/ggml-classification/plugin.d.ts",
      "import": "./dist/_sdk/server/bare/plugins/ggml-classification/plugin.js"
    },
    "./plugin-utils": {
      "types": "./dist/_sdk/schemas/plugin.d.ts",
      "import": "./dist/_sdk/schemas/plugin.js"
    },
    "./worker-core": {
      "import": "./dist/_sdk/server/worker-core.js"
    },
    "./plugins": {
      "import": "./dist/_sdk/server/plugins/index.js"
    },
    "./logging": {
      "import": "./dist/_sdk/logging/index.js"
    },
    "./commands": {
      "types": "./dist/_sdk/commands/index.d.ts",
      "import": "./dist/_sdk/commands/index.js"
    },
    "./models": {
      "types": "./dist/_sdk/models/registry/index.d.ts",
      "import": "./dist/_sdk/models/registry/index.js",
      "require": "./dist/_sdk/models/registry/index.js"
    }
  },
  "imports": {
    "#polyfill-bare-globals": {
      "bare": "./dist/_sdk/polyfills/bare-globals.js",
      "default": "./dist/_sdk/polyfills/bare-globals.noop.js"
    },
    "#rpc": "./dist/_sdk/client/rpc/bare-client.js"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "!**/package-lock.json",
    "!**/yarn.lock",
    "!**/pnpm-lock.yaml",
    "!**/bun.lock",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "bundle": "node ./scripts/bundle-from-sdk.mjs",
    "check:no-addon-deps": "node ./scripts/check-no-addon-deps.mjs",
    "check:no-addon-leaks": "node ./scripts/check-no-addon-leaks.mjs",
    "check:deps-vs-sdk": "node ./scripts/check-deps-vs-sdk.mjs",
    "build": "rm -rf dist && bun run bundle && bun run check:no-addon-deps && bun run check:no-addon-leaks && bun run check:deps-vs-sdk"
  },
  "dependencies": {
    "@qvac/decoder-audio": "^0.3.7",
    "@qvac/error": "^0.1.1",
    "@qvac/langdetect-text": "^0.1.2",
    "@qvac/logging": "^0.1.0",
    "@qvac/rag": "^0.6.2",
    "@qvac/registry-client": "^0.6.0",
    "bare-abort-controller": "^1.0.0",
    "bare-crypto": "^1.15.0",
    "bare-fetch": "^2.9.1",
    "bare-fs": "^4.5.1",
    "bare-net": "^2.3.2",
    "bare-os": "^3.6.2",
    "bare-path": "^3.0.1",
    "bare-process": "^4.2.2",
    "bare-rpc": "^1.3.2",
    "bare-stream": "^2.7.0",
    "bare-zlib": "^1.3.1",
    "corestore": "^7.4.5",
    "fast-safe-stringify": "2.1.1",
    "hyperdrive": "^13.0.1",
    "hyperswarm": "^4.14.0",
    "semver": "^7.8.0",
    "tar-stream": "^3.1.8",
    "which-runtime": "^1.3.2",
    "zod": "^4.3.0",
    "compact-encoding": "^3.0.0"
  }
}
