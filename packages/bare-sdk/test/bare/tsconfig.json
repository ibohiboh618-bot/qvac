{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "../dist/bare",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmitOnError": false
  },
  "include": ["assembly.test.ts"]
}
