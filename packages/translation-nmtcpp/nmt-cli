#!/usr/bin/env bare
'use strict'

// QVAC NMT CLI - Neural Machine Translation Command-Line Tool
//
// IMPORTANT: This tool is used by the quality evaluation framework
// (benchmarks/quality_eval/translators/qvac.py). Please maintain backward
// compatibility when making changes.
//
// Usage: bare nmt-cli [OPTIONS] <source_lang> <target_lang>
// Reads text from stdin (one sentence per line) and outputs translations to stdout

const process = require('bare-process')
const TranslationNmtcpp = require('./index.js')
const { TranslationInterface } = require('./marian.js')

const VERSION = '0.1.4'
const fs = require('bare-fs')
const path = require('bare-path')
const os = require('bare-os')

// Supported OPUS/IndicTrans language pairs. Models are loaded from a local
// GGML file (via --model or QVAC_MODEL_PATH); Bergamot mode (--bergamot) has
// its own model discovery and ignores this list.
const SUPPORTED_PAIRS = [
  'en-it', 'en-de', 'en-es', 'de-en', 'de-es', 'de-it',
  'es-de', 'es-en', 'es-it', 'it-de', 'it-en', 'it-es',
  // Portuguese pairs
  'en-pt', 'pt-en',
  // French pairs
  'en-fr', 'fr-en', 'fr-de', 'fr-es', 'fr-it', 'de-fr', 'es-fr', 'it-fr',
  // Additional language pairs
  'en-zh', 'zh-en', 'en-ar', 'ar-en', 'en-ja', 'ja-en', 'en-ko', 'ko-en',
  'en-ru', 'ru-en', 'en-hi', 'hi-en', 'en-tr', 'tr-en', 'en-vi', 'vi-en',
  'en-fa', 'fa-en', 'en-th', 'th-en', 'en-pl', 'pl-en', 'en-uk', 'uk-en',
  'en-nl', 'nl-en', 'en-ro', 'ro-en', 'en-id', 'id-en', 'en-bn', 'bn-en',
  'en-ur', 'ur-en', 'en-el', 'el-en', 'en-cs', 'cs-en', 'en-sv', 'sv-en',
  'en-hu', 'hu-en', 'en-he', 'he-en', 'en-fi', 'fi-en', 'en-no', 'no-en',
  'en-da', 'da-en', 'en-bg', 'bg-en', 'en-sk', 'sk-en', 'en-lt', 'lt-en',
  'en-lv', 'lv-en', 'en-sl', 'sl-en', 'en-et', 'et-en', 'en-hr', 'hr-en',
  'en-sr', 'sr-en', 'en-ca', 'ca-en'
]

function showHelp () {
  console.log(`
QVAC NMT CLI v${VERSION} - Neural Machine Translation Command-Line Tool

USAGE:
  bare nmt-cli [OPTIONS] <source_lang> <target_lang>

DESCRIPTION:
  Translates text from stdin using QVAC NMT models. Reads one sentence per line
  from stdin and outputs translations to stdout. A model must be provided via
  --model or QVAC_MODEL_PATH (local GGML file), or via --bergamot (Firefox models).

OPTIONS:
  -h, --help              Show this help message and exit
  -v, --version           Show version information and exit
  -m, --model PATH        Path to local GGML model file (overrides QVAC_MODEL_PATH)
  --cpu                   Use CPU instead of GPU for translation (default: GPU)
  --bergamot              Use Bergamot model format (Firefox translations models)
  --batch                 Use batch translation API (Bergamot only, faster for multiple texts)
  --model-dir PATH        Directory containing Bergamot models (default: ~/.local/share/bergamot/models/firefox)

HYPERPARAMETERS:
  --beamsize NUM          Beam size for translation (1=greedy, 4=default)
  --lengthpenalty NUM     Length penalty (0.0-2.0, default: 1.0)
  --repetitionpenalty NUM Repetition penalty (1.0-2.0, default: 1.0)
  --norepeatngramsize NUM No-repeat N-gram size (0-10, default: 0)
  --temperature NUM       Sampling temperature (0.0-2.0, default: 1.0)
  --topk NUM              Top-K sampling (0=disabled, default: 0)
  --topp NUM              Top-P nucleus sampling (0.0-1.0, default: 1.0)
  --maxlength NUM         Maximum output length (default: 512)

ARGUMENTS:
  <source_lang>           Source language code (e.g., en, de, es, it)
  <target_lang>           Target language code (e.g., en, de, es, it)

SUPPORTED LANGUAGE PAIRS:
  ${SUPPORTED_PAIRS.join(', ')}

ENVIRONMENT VARIABLES:
  QVAC_MODEL_PATH         Path to local GGML model file (alternative to --model)
  FIREFOX_MODELS_DIR      Directory for Bergamot models (alternative to --model-dir)

EXAMPLES:
