{
  "dependencies": [
    "bergamot-translator",
    {
      "name": "qvac-lib-inference-addon-cpp",
      "version>=": "1.2.0"
    },
    {
      "name": "qvac-lint-cpp",
      "version>=": "1.4.4#3"
    },
    "sentencepiece",
    "ssplit",
    {
      "name": "qvac-fabric",
      "version>=": "8828.0.1",
      "default-features": false,
      "features": [
        "gpu-backends"
      ]
    }
  ],
  "default-features": ["kleidiai"],  
  "features": {
    "tests": {
      "description": "Build tests",
      "dependencies": [
        "gtest"
      ]
    },
    "kleidiai": {
      "description": "Enable ARM KleidiAI optimized kernels for Android ARM64",
      "dependencies": [
        {
          "name": "qvac-fabric",
          "version>=": "8828.0.1",
          "features": [
            "kleidiai"
          ],
          "platform": "arm64"
        }
      ]
    }
  },
  "overrides": [
    {
      "name": "flatbuffers",
      "version": "23.5.26"
    }
  ]
}
