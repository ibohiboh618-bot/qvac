{
  "name": "ggml",
  "version-date": "2026-01-30",
  "port-version": 7,
  "description": "Tensor library for machine learning (tetherto fork; classification-ggml overlay adds qvac-classif-ggml backend filename prefix and dlopen guard, mirrors qvac-fabric-llm.cpp#95 with addon-specific namespace to prevent cross-addon collisions on Android)",
  "homepage": "https://github.com/tetherto/qvac-ext-ggml",
  "license": "MIT",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    {
      "name": "metal",
      "platform": "osx | ios"
    },
    {
      "name": "opencl",
      "platform": "android"
    },
    {
      "name": "vulkan",
      "platform": "windows | linux | android"
    }
  ],
  "features": {
    "cuda": {
      "description": "Enable CUDA GPU backend"
    },
    "metal": {
      "description": "Enable Metal GPU backend (macOS/iOS)"
    },
    "opencl": {
      "description": "Enable OpenCL GPU backend",
      "dependencies": [
        "opencl"
      ]
    },
    "vulkan": {
      "description": "Enable Vulkan GPU backend"
    }
  }
}
