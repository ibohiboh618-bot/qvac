{
  "name": "ggml",
  "version-date": "2026-06-06",
  "port-version": 3,
  "description": "Tensor library for machine learning (tetherto fork with overlay patches pre-applied; includes Wan IM2COL_3D support plus merged Flux RoPE and direct Metal conv2d kernels)",
  "homepage": "https://github.com/tetherto/qvac-ext-ggml",
  "license": "MIT",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    {
      "name": "metal",
      "platform": "osx | ios"
    },
    {
      "name": "opencl",
      "platform": "android"
    },
    {
      "name": "vulkan",
      "platform": "windows | linux | android"
    }
  ],
  "features": {
    "cuda": {
      "description": "Enable CUDA GPU backend"
    },
    "metal": {
      "description": "Enable Metal GPU backend (macOS/iOS)"
    },
    "opencl": {
      "description": "Enable OpenCL GPU backend",
      "dependencies": [
        "opencl"
      ]
    },
    "vulkan": {
      "description": "Enable Vulkan GPU backend"
    }
  }
}
