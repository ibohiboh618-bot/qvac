{
  "name": "ggml",
  "version-date": "2026-07-01",
  "port-version": 1,
  "description": "Tensor library for machine learning (tetherto fork with fabric Adreno OpenCL fixes incl. leaf-to-root buffer teardown, and QVAC sd.cpp kernels)",
  "homepage": "https://github.com/tetherto/qvac-ext-ggml",
  "license": "MIT",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    {
      "name": "metal",
      "platform": "osx | ios"
    },
    {
      "name": "opencl",
      "platform": "android"
    },
    {
      "name": "vulkan",
      "platform": "windows | linux | android"
    }
  ],
  "features": {
    "cuda": {
      "description": "Enable CUDA GPU backend"
    },
    "metal": {
      "description": "Enable Metal GPU backend (macOS/iOS)"
    },
    "opencl": {
      "description": "Enable OpenCL GPU backend",
      "dependencies": [
        "opencl"
      ]
    },
    "vulkan": {
      "description": "Enable Vulkan GPU backend",
      "dependencies": [
        {
          "name": "spirv-headers",
          "platform": "!osx & !ios",
          "version>=": "1.4.341.0"
        }
      ]
    }
  }
}
