{#- Render a single ApiObject as an MDX page.
    Receives: { obj: ApiObject }
    Two layouts:
      1. "Namespace" layout when `obj.methods` is non-empty: shows an object
         signature block, a Methods index table, and one subsection per method.
      2. "Data object" layout when `obj.methods` is empty: shows a Fields table
         and expanded child types.
    Globals: renderExpandedTypes, renderObjectMethod -#}
---
title: "{{ obj.name }}"
titleStyle: code
description: {{ (obj.description or "No description available") | firstSentence }}
---

{% if obj.descriptionSource == "ai" %}
<Callout type="info" title="AI-generated description">
This description was generated by AI. Verify accuracy before relying on it.
</Callout>

{% endif %}
{% if obj.objectSignature %}
```ts
{{ obj.objectSignature }}
```
{% if obj.leadParagraph %}

{{ obj.leadParagraph }}
{% endif %}

{% endif %}
{% if obj.methods and obj.methods.length > 0 %}
## Methods

| Method | Description |
| --- | --- |
{% for m in obj.methods %}
| [`{{ m.name }}()`](#{{ m.name | lower }}) | {{ (m.summary or m.description or "—") | firstSentence | escapeTableLight }} |
{% endfor %}

{% for m in obj.methods %}
{{ renderObjectMethod(m, 3) }}

{% endfor %}
{% elif obj.fields.length > 0 %}
{%- set hasDefaults = false -%}
{%- for f in obj.fields -%}
  {%- if f.defaultValue -%}{%- set hasDefaults = true -%}{%- endif -%}
{%- endfor -%}
## Fields

{% if hasDefaults %}
| Field | Type | Required? | Default | Description |
| --- | --- | :---: | --- | --- |
{% for f in obj.fields %}
| {{ f.name }} | `{{ f.type | escapeTableLight }}` | {{ "✓" if f.required else "✗" }} | {{ ("`" + f.defaultValue | escapeTableLight + "`") if f.defaultValue else "—" }} | {{ f.description | escapeTableLight or "—" }} |
{% endfor %}
{% else %}
| Field | Type | Required? | Description |
| --- | --- | :---: | --- |
{% for f in obj.fields %}
| {{ f.name }} | `{{ f.type | escapeTableLight }}` | {{ "✓" if f.required else "✗" }} | {{ f.description | escapeTableLight or "—" }} |
{% endfor %}
{% endif %}
{% endif %}
{% if obj.children.length > 0 %}

{{ renderExpandedTypes(obj.children, 3) }}
{% endif %}
{% if obj.examples and obj.examples.length > 0 %}

## Example
{% if obj.examplesSource == "ai" %}

<Callout type="info" title="AI-generated example">
This example was generated by AI. Verify correctness before using in production.
</Callout>
{% endif %}

{% for ex in obj.examples %}
```typescript
{{ ex | stripFence }}
```
{% if not loop.last %}

{% endif %}
{% endfor %}
{% endif %}
