{#- Render a single ApiFunction as an MDX page.
    Receives: { fn: ApiFunction }
    Filters: escapeTableLight, escapeQuotes, slugify, stripFence
    Globals: renderExpandedTypes -#}
---
title: "{{ fn.name }}( )"
titleStyle: code
description: "{{ (fn.description or "No description available") | escapeQuotes | replace("undefined", "—") }}"
---

{% if fn.deprecated %}
<Callout type="warn" title="Deprecated">
{{ fn.deprecated }}
</Callout>

{% endif %}
{% if fn.descriptionSource == "ai" %}
<Callout type="info" title="AI-generated description">
This description was generated by AI. Verify accuracy before relying on it.
</Callout>

{% endif %}
<WrapCode>

```typescript
{{ fn.signature }}
```

</WrapCode>

{% if fn.parameters.length > 0 %}
{% set hasDefaults = false %}
{% for p in fn.parameters %}{% if p.defaultValue %}{% set hasDefaults = true %}{% endif %}{% endfor %}
## Parameters

{% if hasDefaults %}
| Name | Type | Required? | Default | Description |
| --- | --- | :---: | --- | --- |
{% else %}
| Name | Type | Required? | Description |
| --- | --- | :---: | --- |
{% endif %}
{% for p in fn.parameters %}{{ renderParamRow(p, fn.expandedParams, hasDefaults) }}
{% endfor %}
{% if fn.expandedParams.length > 0 %}

{{ renderExpandedTypes(fn.expandedParams, 3) }}
{% endif %}
{% endif %}

## Returns

```typescript
{{ fn.returns.type or "unknown" }}
```

{{ (fn.returns.description or "No description available") | replace("undefined", "—") }}
{% if fn.returnFields.length > 0 %}

| Field | Type | Description |
| --- | --- | --- |
{% for f in fn.returnFields %}
| `{{ f.name }}` | `{{ f.type | escapeTableLight }}` | {{ (f.description or "—") | escapeTableLight }} |
{% endfor %}
{% endif %}
{% if fn.expandedReturns.length > 0 %}

{{ renderExpandedTypes(fn.expandedReturns, 3) }}
{% endif %}

{% if fn.throws and fn.throws.length > 0 %}
## Throws

| Error | When |
| --- | --- |
{% for t in fn.throws %}
| `{{ t.error | escapeTableLight }}` | {{ (t.description or "—") | escapeTableLight }} |
{% endfor %}

{% endif %}
{% if fn.examples and fn.examples.length > 0 %}
## Example
{% if fn.examplesSource == "ai" %}

<Callout type="info" title="AI-generated example">
